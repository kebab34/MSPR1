# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...          # anon/public key
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (admin)

# Database (connexion directe PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# JWT — doit correspondre au "JWT Secret" de ton projet Supabase
# Settings > API > JWT Secret
JWT_SECRET=your-supabase-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
